---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Partner inquiry, demo request, or API access for Clarifid.">
  <section class="mx-auto max-w-6xl px-6 py-24">
    <h1 class="font-serif text-4xl font-normal text-white md:text-5xl">Contact</h1>
    <p class="mt-6 max-w-2xl text-xl text-slate-400">
      Interested in partnering, requesting a demo, or integrating Clarifid into your platform? Get in touch.
    </p>
  </section>

  <section class="border-t border-slate-800/50">
    <div class="mx-auto max-w-2xl px-6 py-24">
      <form class="space-y-6" action="#" method="POST">
        <div>
          <label for="name" class="block text-sm font-medium text-slate-300">Name</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="mt-2 block w-full rounded-md border border-slate-700 bg-slate-900/50 px-4 py-3 text-white placeholder-slate-500 focus:border-amber-500 focus:outline-none focus:ring-1 focus:ring-amber-500"
            placeholder="Your name"
          />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-slate-300">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="mt-2 block w-full rounded-md border border-slate-700 bg-slate-900/50 px-4 py-3 text-white placeholder-slate-500 focus:border-amber-500 focus:outline-none focus:ring-1 focus:ring-amber-500"
            placeholder="you@company.com"
          />
        </div>
        <div>
          <label for="company" class="block text-sm font-medium text-slate-300">Company</label>
          <input
            type="text"
            id="company"
            name="company"
            class="mt-2 block w-full rounded-md border border-slate-700 bg-slate-900/50 px-4 py-3 text-white placeholder-slate-500 focus:border-amber-500 focus:outline-none focus:ring-1 focus:ring-amber-500"
            placeholder="Your company"
          />
        </div>
        <div>
          <label for="interest" class="block text-sm font-medium text-slate-300">Interest</label>
          <select
            id="interest"
            name="interest"
            class="mt-2 block w-full rounded-md border border-slate-700 bg-slate-900/50 px-4 py-3 text-white focus:border-amber-500 focus:outline-none focus:ring-1 focus:ring-amber-500"
          >
            <option value="partnership">Partnership / OEM</option>
            <option value="demo">Demo request</option>
            <option value="api">API access</option>
            <option value="other">Other</option>
          </select>
        </div>
        <div>
          <label for="message" class="block text-sm font-medium text-slate-300">Message</label>
          <textarea
            id="message"
            name="message"
            rows="4"
            class="mt-2 block w-full rounded-md border border-slate-700 bg-slate-900/50 px-4 py-3 text-white placeholder-slate-500 focus:border-amber-500 focus:outline-none focus:ring-1 focus:ring-amber-500"
            placeholder="Tell us about your use case..."
          />
        </div>
        <div>
          <button
            type="submit"
            class="rounded-md bg-amber-500 px-6 py-3 text-base font-medium text-slate-950 hover:bg-amber-400 transition-colors"
          >
            Send message
          </button>
        </div>
      </form>
      <p class="mt-8 text-sm text-slate-500">
        Form submission can be connected to Resend, Formspree, or Pages Functions. For now, this is a static form.
      </p>
    </div>
  </section>

  <section class="border-t border-slate-800/50">
    <div class="mx-auto max-w-6xl px-6 py-24">
      <h2 class="font-serif text-2xl font-normal text-white">Headquarters</h2>
      <p class="mt-4 text-slate-400">Montreal, QC, Canada</p>
      <p class="mt-2 text-sm text-slate-500">Federal Corp (CBCA) · PIPEDA-compliant</p>
    </div>
  </section>
</Layout>
