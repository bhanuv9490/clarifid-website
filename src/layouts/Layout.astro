---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Explainable AI Fraud Intelligence for Lending. The transparent fraud shield that explains itself.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap" rel="stylesheet" />
    <title>{title} | Clarifid</title>
  </head>
  <body class="min-h-screen bg-slate-950 text-slate-100 font-sans antialiased">
    <header class="fixed top-0 left-0 right-0 z-50 border-b border-slate-800/50 bg-slate-950/90 backdrop-blur-sm">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 sm:px-6">
        <a href="/" class="font-serif text-xl font-semibold tracking-tight text-white hover:text-amber-400 transition-colors">
          Clarifid
        </a>
        <ul class="flex flex-wrap items-center justify-end gap-4 sm:gap-6 md:gap-8">
          <li><a href="/" class="text-slate-400 hover:text-white transition-colors">Home</a></li>
          <li><a href="/product" class="text-slate-400 hover:text-white transition-colors">Product</a></li>
          <li><a href="/partners" class="text-slate-400 hover:text-white transition-colors">Partners</a></li>
          <li><a href="/contact" class="rounded-md bg-amber-500 px-4 py-2 text-sm font-medium text-slate-950 hover:bg-amber-400 transition-colors">Contact</a></li>
        </ul>
      </nav>
    </header>

    <main class="pt-20">
      <slot />
    </main>

    <footer class="mt-24 border-t border-slate-800/50">
      <div class="mx-auto max-w-6xl px-6 py-12">
        <div class="flex flex-col gap-8 md:flex-row md:items-center md:justify-between">
          <div>
            <span class="font-serif text-lg font-semibold text-white">Clarifid</span>
            <p class="mt-2 text-sm text-slate-500">Explainable AI Fraud Intelligence for Lending. Montreal, QC.</p>
          </div>
          <div class="flex gap-8">
            <a href="/product" class="text-sm text-slate-500 hover:text-slate-300 transition-colors">Product</a>
            <a href="/partners" class="text-sm text-slate-500 hover:text-slate-300 transition-colors">Partners</a>
            <a href="/contact" class="text-sm text-slate-500 hover:text-slate-300 transition-colors">Contact</a>
          </div>
        </div>
        <p class="mt-8 text-xs text-slate-600">Proprietary. All rights reserved.</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --font-serif: 'DM Serif Display', Georgia, serif;
    --font-sans: 'DM Sans', system-ui, sans-serif;
  }
  body {
    font-family: var(--font-sans);
  }
  .font-serif {
    font-family: var(--font-serif);
  }
</style>
